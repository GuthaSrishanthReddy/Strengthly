{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://your-backend-url/api/:path*"
        }
    ],
    "routes": [
        {
            "src": "^/(?!api/).*$",
            "dest": "/index.html"
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false
}
